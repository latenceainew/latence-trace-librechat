# Secrets and config for the lean local TRACE demo loop.
# Copy to scripts/.env.dev-trace-demo and fill in real values.
# scripts/.env.dev-trace-demo is gitignored.
#
# Mongo
#   `fly secrets list -a latenceai-trace-mongo` shows MONGO_INITDB_ROOT_PASSWORD digest;
#   the actual value lives in your local notes from when the Fly Mongo app was created.
MONGO_USERNAME=librechat
MONGO_PASSWORD=replace-me
# LibreChat
#   `fly secrets list -a latenceai-trace-demo` shows the digests; values come from the
#   one-time generation step (`openssl rand -hex 32` for JWT/CREDS_KEY, hex16 for CREDS_IV).
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
CREDS_KEY=replace-me
CREDS_IV=replace-me
# OpenRouter (model gateway used by the LibreChat custom endpoint)
OPENROUTER_KEY=sk-or-v1-replace-me
# RunPod TRACE runtime (consumed by the bridge)
LATENCE_TRACE_URL=https://api.runpod.ai/v2/<endpoint-id>/runsync
LATENCE_TRACE_API_KEY=rpa_replace-me
LATENCE_TRACE_DEPLOYMENT=runpod
LATENCE_TRACE_TIMEOUT=600
# Demo no-auth toggles (defaults are fine; override only if needed)
LATENCE_DEMO_DISABLE_AUTH=true
LATENCE_DEMO_USER_EMAIL=demo+trace@latence.ai
LATENCE_DEMO_USER_NAME=Latence TRACE Demo
